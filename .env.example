# Google Maps JavaScript API key (with Maps JS + Street View enabled, billing on)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-key-here

# Port the server listens on (optional, defaults to 3000)
PORT=3000

# Production only: the public origin allowed to open Socket.IO connections
# e.g. https://worldseek.yourdomain.com  (leave unset in local dev)
ALLOWED_ORIGIN=

# Optional: your own TURN server for voice chat (relays audio when two players
# can't connect peer-to-peer, e.g. behind symmetric NAT). Leave unset to fall
# back to the free Open Relay Project public TURN server. See README → Voice chat & TURN.
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
